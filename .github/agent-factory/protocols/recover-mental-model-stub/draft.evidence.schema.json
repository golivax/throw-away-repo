{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Draft evidence",
  "description": "Evidence produced by the draft agent: a list of clarifying questions to ask the author.",
  "type": "object",
  "required": ["questions"],
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "description": "Non-empty list of clarifying questions.",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier for this question (e.g. 'q1')."
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The question text."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
